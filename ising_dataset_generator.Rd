\name{ising_dataset_generator}
\alias{ising_dataset_generator}
\alias{generate_clean_and_noisy}
\title{2D Ising Clean/Noisy Dataset Generator (Wolff Cluster Updates)}
\description{
Generates paired \emph{clean} and \emph{noisy} two-dimensional Ising spin configurations on an
\eqn{L \times L} lattice with periodic boundary conditions using Wolff cluster updates.
Each saved sample includes temperature \eqn{T}, a phase label \code{F}/\code{P}, and flattened spins.
Noisy observations are created by applying independent spin-flip noise and missingness (masking to 0).
}
\usage{
# This repository provides the generator as a Python script:
# python J5MCD.py
}
\arguments{
  \item{L}{Lattice size (integer). The script writes \code{MCD\{L\}.csv} and \code{MCDN\{L\}.csv}.}
  \item{TOTAL}{Total number of samples (rows) to generate (default: 50,000).}
  \item{N_T}{Number of temperatures (default: 50).}
  \item{T\_MIN, T\_MAX}{Temperature range; temperatures are taken as \code{linspace(T_MIN, T_MAX, N_T)}.}
  \item{EQUIL\_UPDATES}{Number of Wolff cluster flips for equilibration (burn-in).}
  \item{GAP\_UPDATES}{Number of Wolff cluster flips between saved samples (thinning).}
  \item{NOISE\_Q}{Independent spin-flip probability applied to clean spins when creating noisy observations.}
  \item{MASK\_RATE}{Independent masking probability; masked spins are set to 0 in the noisy lattice.}
  \item{SEED}{Random seed for reproducibility.}
}
\details{
\strong{Clean dataset (MCD\{L\}.csv).}
For each temperature value \eqn{T}, the generator initializes a random configuration
\eqn{s_{ij} \in \{-1,+1\}} and applies Wolff updates for equilibration, followed by \code{GAP_UPDATES}
between consecutive saved samples. Each clean row has the schema:
\code{Temperature, Phase, spin_0, \dots, spin_{L^2-1}}.

\strong{Phase labeling.}
The phase label is assigned as \code{F} if \eqn{T < T_c} and \code{P} otherwise, with \eqn{T_c \approx 2.269}.
(See the generator logic where \code{phase_label = "F" if T < Tc else "P"}.)

\strong{Noisy dataset (MCDN\{L\}.csv).}
The noisy row is aligned with the corresponding clean row and is generated by (i) flipping each spin with
probability \code{NOISE_Q} and then (ii) masking each site to 0 with probability \code{MASK_RATE}.
}
\value{
Two CSV files saved to the output directory (default: \code{J5Data/}):
\itemize{
  \item \code{MCD\{L\}.csv}: clean configurations \eqn{s_{ij} \in \{-1,+1\}}.
  \item \code{MCDN\{L\}.csv}: noisy/masked configurations \eqn{y_{ij} \in \{-1,0,+1\}} (0 = missing).
}
A metadata CSV is also appended/created (see \code{write_metadata()} in the script), logging run settings and timing.
}
\references{
Metropolis, N., Rosenbluth, A. W., Rosenbluth, M. N., Teller, A. H., and Teller, E. (1953).
Equation of state calculations by fast computing machines.
\emph{Journal of Chemical Physics}, 21(6), 1087--1092.

Wolff, U. (1989). Collective Monte Carlo updating for spin systems.
\emph{Physical Review Letters}, 62(4), 361--364.
}
\examples{
# From a shell/terminal (recommended):
#   python J5MCD.py
#
# Outputs (default):
#   J5Data/MCD128.csv
#   J5Data/MCDN128.csv
#
# To change L or noise settings, edit the "USER PARAMETERS" block near the top of J5MCD.py.
}
